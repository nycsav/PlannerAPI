# PlannerAPI Environment Variables
# Copy this file to .env and fill in your actual keys
# IMPORTANT: .env should NEVER be committed to git

# ============================================================================
# FIREBASE CONFIGURATION (Frontend - Client-side)
# ============================================================================
# Get these from: Firebase Console → Project Settings → General

VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_PROJECT_ID=plannerapi-prod
VITE_FIREBASE_SENDER_ID=your_firebase_sender_id_here
VITE_FIREBASE_APP_ID=your_firebase_app_id_here

# ============================================================================
# PERPLEXITY API CONFIGURATION (Client-side)
# ============================================================================
# Get from: https://www.perplexity.ai/settings/api
# NOTE: This is currently a placeholder for future client-side usage
# Currently Perplexity is only called from Cloud Functions

VITE_PPLX_API_KEY=your_perplexity_api_key_here
VITE_PPLX_MODEL_FAST=sonar

# ============================================================================
# GOOGLE ANALYTICS (Optional)
# ============================================================================
# Get from: Google Analytics 4 → Admin → Data Streams

VITE_GA4_MEASUREMENT_ID=G-XXXXXXXXXX

# ============================================================================
# NOTION INTEGRATION (Backend - n8n Automation)
# ============================================================================
# Get from: Notion Settings → Integrations → Internal integrations
# Database ID: Found in Notion database URL

NOTION_API_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_DATABASE_ID=2fa0bdffe59e8075a696000b88058c9e

# ============================================================================
# AI SERVICES (Backend - Cloud Functions)
# ============================================================================
# Anthropic Claude API: https://console.anthropic.com/settings/keys
# Note: Use Firebase Functions config for production:
#   firebase functions:config:set anthropic.api_key="YOUR_KEY"

ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ============================================================================
# NOTES FOR DEVELOPMENT
# ============================================================================
# - Never share or commit your actual .env file
# - Keep .env listed in .gitignore
# - For production, use Firebase Functions config or GitHub Secrets
# - For local development, just create .env in the project root
# - Claude API key managed via Anthropic dashboard
